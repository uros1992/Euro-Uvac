rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    function isValidReservation(data) {
      return data.keys().hasAll(['userId', 'date', 'seats', 'status', 'createdAt'])
        && data.keys().size() == 5
        && data.userId is string && data.userId.size() <= 128
        && data.userId == request.auth.uid
        && data.date is string && data.date.size() <= 50
        && data.seats is list && data.seats.size() <= 12
        && (data.seats.size() == 0 || data.seats[0] is number)
        && data.status is string && data.status.size() <= 20
        && data.status in ['confirmed', 'cancelled'];
    }

    function isCancelAction() {
      return incoming().status == 'cancelled' && existing().status == 'confirmed';
    }

    function isValidReview(data) {
      return data.keys().hasAll(['name', 'text', 'rating', 'createdAt'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 50
        && data.text is string && data.text.size() > 0 && data.text.size() <= 1000
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.createdAt == request.time;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidId(reviewId) && isValidReview(incoming());
      allow update: if false; // Reviews are immutable
      allow delete: if isAdmin() && isValidId(reviewId);
    }

    match /reservations/{reservationId} {
      // Base docs are safely readable because they contain no PII, allowing calendar availability functions
      allow read: if true; 

      allow create: if isSignedIn() && isValidId(reservationId) && isValidReservation(incoming());

      allow update: if isSignedIn() && isValidId(reservationId) 
        && (
          isAdmin() || 
          (
            existing().userId == request.auth.uid &&
            isCancelAction() &&
            incoming().diff(existing()).affectedKeys().hasOnly(['status'])
          )
        );
      
      allow delete: if isAdmin() && isValidId(reservationId);

      // Protect PII strictly
      match /details/info {
         allow read: if isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/reservations/$(reservationId)).data.userId == request.auth.uid);
         allow create: if isSignedIn() 
            && incoming().keys().hasAll(['name', 'email', 'phone'])
            && incoming().name is string
            && incoming().email is string
            && incoming().phone is string;
         allow update: if false;
         allow delete: if isAdmin();
      }
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && (isValidId(userId) || request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId && request.auth.token.email == 'TheMan.Uros@gmail.com';
      allow write: if false; 
    }
  }
}
